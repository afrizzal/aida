{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "files": {
    "includes": [
      "**/*.{ts,tsx,js,jsx,json}",
      "!**/node_modules",
      "!**/.next",
      "!**/src/generated",
      "!**/prisma/generated",
      "!.planning"
    ]
  }
}
