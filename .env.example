# --- App ---
# For Docker Compose behind Caddy: use the public URL (http://localhost or https://yourdomain.com)
# For local dev without Docker: http://localhost:3000
BETTER_AUTH_URL=http://localhost
NEXT_PUBLIC_APP_URL=http://localhost
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-secret
# Comma-separated extra origins to trust for CSRF checks (covers HTTP + HTTPS local dev)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost,https://localhost

# --- Database (Postgres 16 + pgvector) ---
DATABASE_URL=postgresql://aida:aida@localhost:5432/aida
POSTGRES_USER=aida
POSTGRES_PASSWORD=aida
POSTGRES_DB=aida

# --- Reverse proxy (Caddy) ---
# localhost for local dev; a real domain enables Let's Encrypt auto-HTTPS in prod
DOMAIN=localhost

# --- Connection pool sizing ---
# app_pool + worker_pool must be < Postgres max_connections (default 100).
# Compose overrides per-service (app=10, worker=5); set here for local dev without Docker.
DB_POOL_MAX=10

# --- First-run admin bootstrap (OPTIONAL, headless/CI installs) ---
# If set on a fresh instance, the app auto-creates the first org + admin and skips the /setup wizard.
# Leave blank to use the interactive /setup wizard instead. NEVER ship default creds.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# --- Attachments & public intake (AIDA-08) ---
# Local filesystem path for stored attachments (Docker: the uploads_data volume mount).
UPLOADS_DIR=/data/uploads
# Generate with: openssl rand -base64 32
# Salts the per-IP hash used by the public-intake rate limiter (never stores raw IPs).
RATE_LIMIT_PEPPER=replace-me-with-a-random-pepper
