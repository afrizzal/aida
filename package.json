{
  "name": "aida",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/lib/worker/index.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-auth": "1.6.22",
    "next": "16.2.9",
    "next-themes": "0.4.6",
    "pg": "8.22.0",
    "pg-boss": "12.23.0",
    "prisma": "7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.1",
    "zod": "4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testcontainers/postgresql": "12.0.3",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.16",
    "testcontainers": "12.0.3",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "vitest-environment-prisma-postgres": "2.0.0"
  }
}
